<Window x:Class="ArtisanalVCS.Client.Views.CreateProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project" Height="550" Width="550"
        Background="{StaticResource AppBg}" Foreground="{StaticResource TextFgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Create Project" FontSize="20" Foreground="{StaticResource AccentFg}"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Name"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

            <TextBlock Text="Description"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                     TextWrapping="Wrap" Height="50" Margin="0,0,0,8"/>

            <CheckBox Content="Public" IsChecked="{Binding IsPublic}" Margin="0,0,0,8"
                       Foreground="{StaticResource TextFgBrush}"/>

            <TextBlock Text="Project folder"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding ProjectFolder, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0"
                         IsReadOnly="True" Foreground="{StaticResource TextMutedBrush}"/>
                <Button Content="Browse" Command="{Binding BrowseFolderCommand}" Grid.Column="1" Margin="5,0,0,0"/>
            </Grid>

            <Button Content="Create" Command="{Binding CreateCommand}" Height="32"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerFg}"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
