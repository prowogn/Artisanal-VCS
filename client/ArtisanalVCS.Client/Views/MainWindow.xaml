<Window x:Class="ArtisanalVCS.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArtisanalVCS" Height="800" Width="1100"
        Background="{StaticResource AppBg}" Foreground="{StaticResource TextFgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="ArtisanalVCS" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource AccentFg}" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200"
                     VerticalAlignment="Center"/>
            <Button Content="Search" Command="{Binding SearchCommand}" Margin="5,0"/>
            <Button Content="{Binding ToggleButtonText}" Command="{Binding ToggleViewCommand}" Margin="5,0"/>
            <Button Content="+ New" Command="{Binding CreateProjectCommand}" Margin="20,0,0,0"
                    Foreground="{StaticResource SuccessFg}"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="20,0,0,0"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <Button Content="выйти" Command="{Binding LogoutCommand}"
                    Margin="20,0,0,0" Foreground="{StaticResource DangerFg}"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Projects}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="12,8" Margin="0,0,0,6"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding OwnerName, StringFormat='by {0}'}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="{Binding MemberCount, StringFormat='👤 {0}'}"
                                           Margin="0,0,10,0" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="🔒" Visibility="{Binding IsPublic, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                <Button Content="Delete" Foreground="{StaticResource DangerFg}"
                                        Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding IsOwner, Converter={StaticResource BoolToVis}}"
                                        Margin="5,0,0,0" Padding="6,2" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</Window>
