<Window x:Class="ArtisanalVCS.Client.Views.CreateCommitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Commit" Height="650" Width="600"
        Background="{StaticResource AppBg}" Foreground="{StaticResource TextFgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="New Commit" FontSize="20" Foreground="{StaticResource AccentFg}"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Branch"/>
            <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                      Margin="0,0,0,8"/>

            <TextBlock Text="Message"/>
            <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

            <Border Background="{StaticResource PanelBg}" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Project Folder" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ProjectFolder, Mode=OneWay}" IsReadOnly="True"
                                 Foreground="{StaticResource TextMutedBrush}" Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseFolderCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Files.Count, StringFormat='Files: {0}'}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ListBox ItemsSource="{Binding Files}" Height="120" Margin="0,0,0,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBg}" CornerRadius="4" Padding="6,3" Margin="0,0,0,3">
                            <TextBlock Text="{Binding FilePath}" FontWeight="SemiBold"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Content="Create Commit" Command="{Binding CreateCommand}" Height="36"
                    Background="{StaticResource AccentFg}" Foreground="Black" FontWeight="Bold"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerFg}"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>

            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </Grid>
</Window>
