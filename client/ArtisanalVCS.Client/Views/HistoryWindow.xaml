<Window x:Class="ArtisanalVCS.Client.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commit History" Height="800" Width="950"
        Background="{StaticResource AppBg}" Foreground="{StaticResource TextFgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Commits" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource AccentFg}" Margin="0,0,0,8"/>
            <ListBox ItemsSource="{Binding Commits}" SelectedItem="{Binding SelectedCommit, Mode=TwoWay}"
                     Height="500" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBg}" CornerRadius="6" Padding="8,4" Margin="0,0,0,4"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectCommitCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <TextBlock Text="{Binding Message}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:g}'}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding AuthorName, StringFormat='by {0}'}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding BranchName, StringFormat='[{0}]'}"
                                           Foreground="{StaticResource AccentFg}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Details" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource AccentFg}" Margin="0,0,0,8"/>
            <ScrollViewer Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1" VerticalScrollBarVisibility="Auto" Height="450">
                <TextBlock Text="{Binding CommitDetail}" TextWrapping="Wrap" FontFamily="Consolas"
                           Padding="8" Foreground="{StaticResource TextFgBrush}"/>
            </ScrollViewer>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Rollback" Command="{Binding RollbackCommand}" Margin="0,0,8,0"
                        Foreground="{StaticResource DangerFg}"/>
                <Button Content="Download ZIP" Command="{Binding DownloadZipCommand}"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <ProgressBar Grid.ColumnSpan="2" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</Window>
