<Window x:Class="ArtisanalVCS.Client.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register" Height="550" Width="450"
        Background="{StaticResource AppBg}" Foreground="{StaticResource TextFgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Registration" FontSize="20" Foreground="{StaticResource AccentFg}"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Username"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

            <TextBlock Text="Email"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" PasswordChanged="OnPasswordChanged" Margin="0,0,0,8"/>

            <TextBlock Text="Confirm password"/>
            <PasswordBox x:Name="ConfirmPasswordBox" PasswordChanged="OnConfirmChanged" Margin="0,0,0,12"/>

            <Button Content="Register" Command="{Binding RegisterCommand}" Height="32"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerFg}"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
